# Copy to .env.local (or .env) and fill in. Never commit real secrets.

# --- Supabase (browser + server) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only; full DB access — never expose to client or logs
SUPABASE_SERVICE_ROLE_KEY=

# Optional tenant defaults (see supabase migrations)
NEXT_PUBLIC_BUSINESS_ID=
NEXT_PUBLIC_DEFAULT_TEACHER_ID=
NEXT_PUBLIC_SUPABASE_APPOINTMENTS_TABLE=
NEXT_PUBLIC_SUPABASE_CLIENTS_TABLE=

# App URL (OAuth callbacks, emails)
NEXT_PUBLIC_APP_URL=

# --- Stripe ---
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Email (Resend) ---
# EMAIL_PROVIDER=resend   # default: resend if RESEND_API_KEY set, else console
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# --- Messaging (SMS / WhatsApp) ---
# MESSAGING_PROVIDER=console   # console | twilio
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=+972501234567
# TWILIO_WHATSAPP_NUMBER=+14155238886

# --- Cron (optional — Vercel sends x-vercel-cron header automatically) ---
# CRON_SECRET=

# --- Google Calendar integration ---
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REDIRECT_URI=
GOOGLE_CALENDAR_TOKEN_ENCRYPTION_KEY=
GOOGLE_CALENDAR_OAUTH_STATE_SECRET=
GOOGLE_CALENDAR_DEFAULT_TIMEZONE=Asia/Jerusalem

# --- Optional debugging (auth) ---
# AUTH_LOGIN_DEBUG=1
# AUTH_LOGIN_REPAIR_BUSINESS_ID=1

# --- Optional AI reminders ---
# OPENAI_API_KEY=
